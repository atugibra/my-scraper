{
  "manifest_version": 3,
  "name": "Football League Auto Saver",
  "version": "1.0",
  "description": "Automatically saves FBref football league pages to your computer",
  "permissions": [
    "downloads",
    "tabs",
    "scripting",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://fbref.com/*",
    "https://www.football-data.co.uk/*",
    "https://www.transfermarkt.com/*",
    "https://api.openweathermap.org/*",
    "http://localhost:8000/*",
    "http://localhost:5000/*",
    "http://localhost:4000/*",
    "https://plusone-backend-production.up.railway.app/*",
    "https://football-analytics-production-5b3d.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup_enhanced.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "diagnostic_test.html",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}